# AvatarKit Host Mode Demo Server configuration
# Copy this file to .env and fill in your credentials

# Required: Get from https://app.spatialreal.ai/
AVATARKIT_API_KEY=your_api_key_here
AVATARKIT_APP_ID=your_app_id_here

# Region: ap-northeast or us-west
AVATARKIT_REGION=ap-northeast

# Default avatar ID (client can override per-request)
AVATARKIT_AVATAR_ID=your_avatar_id_here

# Session expiry (hours)
AVATARKIT_EXPIRE_HOURS=1

# Audio settings
PCM_FILE_PATH=audio/sample.pcm
SAMPLE_RATE=16000
AUDIO_CHUNK_MS=100

# Server bind
WS_HOST=0.0.0.0
WS_PORT=8765
